# Default: auto-detect text files and normalize to LF on commit, checkout as-is.
# Windows checkouts get LF in the working tree (no auto-CRLF).
* text=auto eol=lf

# Explicit text files (Markdown, code, config)
*.md        text eol=lf
*.txt       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.java      text eol=lf
*.c         text eol=lf
*.h         text eol=lf
*.cpp       text eol=lf
*.hpp       text eol=lf
*.properties text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf
# Windows-only scripts: must keep CRLF or cmd.exe breaks
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
# Binary files: no diff, no merge, no normalization
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.7z        binary
*.rar       binary
*.exe       binary
*.dll       binary
*.dmg       binary
*.mp3       binary
*.mp4       binary
*.mov       binary
*.wav       binary
*.class     binary
*.jar       binary
*.so        binary
*.dylib     binary
*.png filter=lfs diff=lfs merge=lfs -text
*.PNG filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.JPG filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.JPEG filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.PDF filter=lfs diff=lfs merge=lfs -text
*.png !text !filter !merge !diff
*.PNG !text !filter !merge !diff
*.jpg !text !filter !merge !diff
*.JPG !text !filter !merge !diff
*.jpeg !text !filter !merge !diff
*.JPEG !text !filter !merge !diff
*.pdf !text !filter !merge !diff
*.PDF !text !filter !merge !diff
